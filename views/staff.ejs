<%- include('layout', { title: 'จัดการพนักงาน (Staff Management)' , user: user, body: ` 
<div class="card" style="margin-bottom: 2rem;">
    <div class="flex items-center" style="justify-content: space-between; margin-bottom: 1.5rem;">
        <h2>จัดการบัญชีพนักงาน (Staff Accounts)</h2>
        <button class="btn btn-primary" onclick="openAddModal()" style="display: flex; align-items: center; gap: 0.5rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="8.5" cy="7" r="4"></circle>
                <line x1="20" y1="8" x2="20" y2="14"></line>
                <line x1="23" y1="11" x2="17" y2="11"></line>
            </svg>
            เพิ่มพนักงานใหม่
        </button>
    </div>

    ${success ? `
    <div class="alert" style="background-color: #D1FAE5; color: var(--secondary); border: 1px solid #34D399;">
        ${success}
    </div>
    ` : ''}

    ${error ? `
    <div class="alert alert-danger">
        ${error}
    </div>
    ` : ''}

    <div class="table-responsive">
        <table style="width: 100%; border-collapse: collapse; text-align: left;" id="staff-table">
            <thead>
                <tr style="border-bottom: 2px solid var(--border); color: var(--text-muted);">
                    <th style="padding: 1rem;">ชื่อผู้ใช้งาน (Username)</th>
                    <th style="padding: 1rem;">สิทธิ์ (Role)</th>
                    <th style="padding: 1rem;">วันที่เพิ่ม</th>
                    <th style="padding: 1rem; text-align: center;">จัดการ (Actions)</th>
                </tr>
            </thead>
            <tbody>
                ${staffList.length === 0 ? `
                <tr>
                    <td colspan="4" class="text-center text-muted" style="padding: 2rem;">
                        ยังไม่มีบัญชีพนักงานในระบบ (No staff accounts)
                    </td>
                </tr>
                ` : staffList.map(staff => `
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 1rem;"><strong>${staff.username}</strong></td>
                    <td style="padding: 1rem;">
                        <span style="background: rgba(16, 185, 129, 0.1); padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.875rem; color: var(--secondary);">
                            ${staff.role}
                        </span>
                    </td>
                    <td style="padding: 1rem; color: var(--text-muted);">${new Date(staff.createdAt).toLocaleDateString('th-TH')}</td>
                    <td style="padding: 1rem; text-align: center;">
                        <button class="btn" onclick="openResetModal('${staff._id}', '${staff.username}')"
                            style="background-color: var(--bg-input); color: var(--text-main); padding: 0.5rem; font-size: 0.875rem;">
                            เปลี่ยนรหัส
                        </button>

                        <form action="/staff/delete/${staff._id}" method="POST" style="display:inline;"
                            onsubmit="return confirm('ยืนยันการลบบัญชีพนักงาน [${staff.username}] ใช่หรือไม่?');">
                            <button type="submit" class="btn"
                                style="background-color: #FEF2F2; color: var(--danger); padding: 0.5rem; font-size: 0.875rem; margin-left: 0.5rem;">
                                ลบ
                            </button>
                        </form>
                    </td>
                </tr>
                `).join('')}
            </tbody>
        </table>
    </div>
</div>

<!-- Modal CSS -->
<style>
    .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); display: none; align-items: center; justify-content: center; z-index: 50; }
    .modal { background: var(--bg-card); width: 100%; max-width: 400px; border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow-lg); }
    .modal-active { display: flex; }
    .form-group { margin-bottom: 1rem; }
    .form-label { display: block; margin-bottom: 0.5rem; font-weight: 500; font-size: 0.875rem; }
</style>

<!-- Add Staff Modal -->
<div class="modal-overlay" id="addModal">
    <div class="modal">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3>เพิ่มบัญชีพนักงานใหม่</h3>
            <button onclick="closeModal('addModal')" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
        </div>
        <form action="/staff/add" method="POST">
            <div class="form-group">
                <label class="form-label">ชื่อผู้ใช้งาน (Username) - สำหรับเข้าสู่ระบบ</label>
                <input type="text" name="username" class="form-control" required placeholder="เช่น staff01" pattern="[a-zA-Z0-9_]+" title="ใช้อักษรภาษาอังกฤษ ตัวเลข และ _ เท่านั้น">
            </div>
            <div class="form-group">
                <label class="form-label">รหัสผ่าน (Password)</label>
                <input type="password" name="password" class="form-control" required minlength="4">
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem;">
                <button type="button" class="btn" style="background-color: var(--bg-input);" onclick="closeModal('addModal')">ยกเลิก</button>
                <button type="submit" class="btn btn-primary">สร้างบัญชี</button>
            </div>
        </form>
    </div>
</div>

<!-- Reset Password Modal -->
<div class="modal-overlay" id="resetModal">
    <div class="modal">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3>เปลี่ยนรหัสผ่าน</h3>
            <button onclick="closeModal('resetModal')" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
        </div>
        <p style="margin-top: 0; color: var(--text-muted); font-size: 0.875rem;">บัญชี: <strong id="resetTargetUser" style="color: var(--text-main);"></strong></p>
        <form id="resetForm" method="POST">
            <div class="form-group">
                <label class="form-label">รหัสผ่านใหม่ (New Password)</label>
                <input type="password" name="newPassword" class="form-control" required minlength="4">
            </div>
            <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1.5rem;">
                <button type="button" class="btn" style="background-color: var(--bg-input);" onclick="closeModal('resetModal')">ยกเลิก</button>
                <button type="submit" class="btn btn-primary">บันทึกรหัสผ่านใหม่</button>
            </div>
        </form>
    </div>
</div>
`,
extraJs: `
    function openAddModal() {
        document.getElementById('addModal').classList.add('modal-active');
    }

    function openResetModal(userId, username) {
        document.getElementById('resetForm').action = '/staff/reset-password/' + userId;
        document.getElementById('resetTargetUser').textContent = username;
        document.getElementById('resetModal').classList.add('modal-active');
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('modal-active');
    }

    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(el => el.style.display = 'none');
    }, 4000);
`
}) %>
