<%- include('layout', { title: 'จัดการคลังสินค้า' , user: user, body: ` <div class="card" style="margin-bottom: 2rem;">
    <div class="flex items-center" style="justify-content: space-between; margin-bottom: 1.5rem;">
        <h2>รายการสินค้าคงคลัง (Inventory)</h2>
        <div style="display: flex; gap: 0.5rem;">
            <button class="btn" style="background-color: var(--bg-input); color: var(--text-main); display: flex; align-items: center; gap: 0.5rem;" onclick="openScanner()">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 7V4h3"></path><path d="M20 7V4h-3"></path><path d="M4 17v3h3"></path><path d="M20 17v3h-3"></path><rect x="7" y="10" width="10" height="4" rx="1"></rect>
                </svg>
                สแกนกล้อง
            </button>
            <button class="btn btn-primary" onclick="openAddModal()" style="display: flex; align-items: center; gap: 0.5rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                เพิ่มสินค้าใหม่
            </button>
        </div>
    </div>

    ${success ? `
    <div class="alert" style="background-color: #D1FAE5; color: var(--secondary); border: 1px solid #34D399;">
        ${success}
    </div>
    ` : ''}

    ${error ? `
    <div class="alert alert-danger">
        ${error}
    </div>
    ` : ''}

    <div class="table-responsive">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead>
                <tr style="border-bottom: 2px solid var(--border); color: var(--text-muted);">
                    <th style="padding: 1rem;">รหัส (Code)</th>
                    <th style="padding: 1rem;">ชื่อสินค้า (Name)</th>
                    <th style="padding: 1rem;">ประเภท (Category)</th>
                    <th style="padding: 1rem; text-align: center;">หน่วย (Unit)</th>
                    <th style="padding: 1rem; text-align: right;">ราคา (Price)</th>
                    <th style="padding: 1rem; text-align: right;">คงเหลือ (Stock)</th>
                    <th style="padding: 1rem; text-align: right;">น้ำหนัก (Weight)</th>
                    <th style="padding: 1rem; text-align: center;">จัดการ (Actions)</th>
                </tr>
            </thead>
            <tbody>
                ${products.length === 0 ? `
                <tr>
                    <td colspan="8" class="text-center text-muted" style="padding: 2rem;">
                        ไม่มีข้อมูลสินค้า (No products available)
                    </td>
                </tr>
                ` : products.map(product => `
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 1rem;"><strong>${product.code}</strong></td>
                    <td style="padding: 1rem;">${product.name}</td>
                    <td style="padding: 1rem;">
                        <span
                            style="background: var(--bg-app); padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.875rem; color: var(--text-muted);">
                            ${product.category}
                        </span>
                    </td>
                    <td style="padding: 1rem; text-align: center; color: var(--text-muted);">${product.unit || 'ชิ้น'}</td>
                    <td style="padding: 1rem; text-align: right;">฿${product.price.toLocaleString('th-TH')}</td>
                    <td style="padding: 1rem; text-align: right;">
                        ${(product.stock <= 5 && product.stock> 0) ? `
                            <span style="color: var(--warning); font-weight: 600;">${product.stock} ${product.unit || 'ชิ้น'}</span>
                            ` : product.stock === 0 ? `
                            <span style="color: var(--danger); font-weight: 600;">หมด (Out of Stock)</span>
                            ` : `
                            <span style="color: var(--secondary); font-weight: 600;">${product.stock} ${product.unit || 'ชิ้น'}</span>
                            `}
                    </td>
                    <td style="padding: 1rem; text-align: right;">
                        ${(product.weight > 0) ? `${product.weight} กก.` : (['กิโลกรัม', 'กรัม', 'ขีด'].includes(product.unit) ? `${product.stock} ${product.unit}` : '-')}
                    </td>
                    <td style="padding: 1rem; text-align: center;">
                        <button class="btn"
                            style="background-color: var(--bg-input); color: var(--text-main); padding: 0.5rem; font-size: 0.875rem;"
                            onclick="openEditModal('${product._id}')">
                            แก้ไข
                        </button>

                        ${(user.role === 'Owner' || user.userRole === 'Owner') ? `
                        <form action="/products/delete/${product._id}" method="POST" style="display:inline;"
                            onsubmit="return confirm('ยืนยันการลบสินค้า \`${product.name}\` ?');">
                            <button type="submit" class="btn"
                                style="background-color: #FEF2F2; color: var(--danger); padding: 0.5rem; font-size: 0.875rem; margin-left: 0.5rem;">
                                ลบ
                            </button>
                        </form>
                        ` : ''}
                    </td>
                </tr>
                `).join('')}
            </tbody>
        </table>
    </div>
    </div>

    <!-- Modal CSS -->
    <style>
        .modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.5); display: none; align-items: center; justify-content: center; z-index: 50; }
        .modal { background: var(--bg-card); width: 100%; max-width: 500px; border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow-lg); }
        .modal-active { display: flex; }
        .form-group { margin-bottom: 1rem; }
        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 500; font-size: 0.875rem; }
    </style>

    <!-- Add Product Modal -->
    <div class="modal-overlay" id="addModal">
        <div class="modal">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3>เพิ่มสินค้าใหม่</h3>
                <button onclick="closeModal('addModal')" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
            </div>
            <form action="/products/add" method="POST">
                <div class="form-group">
                    <label class="form-label">รหัสสินค้า (Code)</label>
                    <input type="text" name="code" class="form-control" required placeholder="เช่น PRD-001">
                </div>
                <div class="form-group">
                    <label class="form-label">ชื่อสินค้า (Name)</label>
                    <input type="text" name="name" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">หมวดหมู่ (Category)</label>
                    <select name="category" class="form-control" required>
                        <option value="" disabled selected>เลือกหมวดหมู่</option>
                        <option value="อาหารและของกิน 🍜">อาหารและของกิน 🍜</option>
                        <option value="เครื่องดื่ม 🥤">เครื่องดื่ม 🥤</option>
                        <option value="ของใช้ในบ้าน 🏠">ของใช้ในบ้าน 🏠</option>
                        <option value="ของใช้ส่วนตัว 🧴">ของใช้ส่วนตัว 🧴</option>
                        <option value="เครื่องปรุงอาหาร 🍳">เครื่องปรุงอาหาร 🍳</option>
                        <option value="ของสด 🥬">ของสด 🥬</option>
                        <option value="ของแช่แข็ง / แช่เย็น ❄️">ของแช่แข็ง / แช่เย็น ❄️</option>
                        <option value="ของใช้เบ็ดเตล็ด 🔧">ของใช้เบ็ดเตล็ด 🔧</option>
                    </select>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">ราคา (Price)</label>
                        <input type="number" name="price" class="form-control" min="0" step="0.01" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">หน่วยนับ (Unit)</label>
                        <select name="unit" class="form-control" required>
                            <option value="ชิ้น" selected>ชิ้น</option>
                            <option value="แพ็ก">แพ็ก</option>
                            <option value="กิโลกรัม">กิโลกรัม</option>
                            <option value="ถุง">ถุง</option>
                            <option value="ขวด">ขวด</option>
                            <option value="กรัม">กรัม</option>
                        </select>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">จำนวนที่มี (Stock)</label>
                        <input type="number" name="stock" class="form-control" min="0" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">น้ำหนัก (Weight)</label>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <input type="number" name="weight" class="form-control" min="0" step="0.01" value="0">
                            <span style="white-space: nowrap; color: var(--text-main);">กิโลกรัม</span>
                        </div>
                    </div>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                    <button type="button" class="btn" style="background-color: var(--bg-input);" onclick="closeModal('addModal')">ยกเลิก</button>
                    <button type="submit" class="btn btn-primary">บันทึกสินค้า</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit Product Modal -->
    <div class="modal-overlay" id="editModal">
        <div class="modal">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3>แก้ไขข้อมูลสินค้า</h3>
                <button onclick="closeModal('editModal')" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
            </div>
            <form id="editForm" method="POST">
                <div class="form-group">
                    <label class="form-label">รหัสสินค้า (Code)</label>
                    <input type="text" id="editCode" name="code" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">ชื่อสินค้า (Name)</label>
                    <input type="text" name="name" id="editName" class="form-control" required>
                </div>
                <div class="form-group">
                    <label class="form-label">หมวดหมู่ (Category)</label>
                    <select name="category" id="editCategory" class="form-control" required>
                        <option value="อาหารและของกิน 🍜">อาหารและของกิน 🍜</option>
                        <option value="เครื่องดื่ม 🥤">เครื่องดื่ม 🥤</option>
                        <option value="ของใช้ในบ้าน 🏠">ของใช้ในบ้าน 🏠</option>
                        <option value="ของใช้ส่วนตัว 🧴">ของใช้ส่วนตัว 🧴</option>
                        <option value="เครื่องปรุงอาหาร 🍳">เครื่องปรุงอาหาร 🍳</option>
                        <option value="ของสด 🥬">ของสด 🥬</option>
                        <option value="ของแช่แข็ง / แช่เย็น ❄️">ของแช่แข็ง / แช่เย็น ❄️</option>
                        <option value="ของใช้เบ็ดเตล็ด 🔧">ของใช้เบ็ดเตล็ด 🔧</option>
                    </select>
                </div>
                <div style="display: flex; gap: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">ราคา (Price)</label>
                        <input type="number" name="price" id="editPrice" class="form-control" min="0" step="0.01" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">หน่วยนับ (Unit)</label>
                        <select name="unit" id="editUnit" class="form-control" required>
                            <option value="ชิ้น">ชิ้น</option>
                            <option value="แพ็ก">แพ็ก</option>
                            <option value="กิโลกรัม">กิโลกรัม</option>
                            <option value="ถุง">ถุง</option>
                            <option value="ขวด">ขวด</option>
                            <option value="กรัม">กรัม</option>
                        </select>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">จำนวนคงเหลือ (Stock)</label>
                        <input type="number" name="stock" id="editStock" class="form-control" min="0" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label class="form-label">น้ำหนัก (Weight)</label>
                        <div style="display: flex; align-items: center; gap: 0.5rem;">
                            <input type="number" name="weight" id="editWeight" class="form-control" min="0" step="0.01" value="0">
                            <span style="white-space: nowrap; color: var(--text-main);">กิโลกรัม</span>
                        </div>
                    </div>
                </div>
                <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 1rem;">
                    <button type="button" class="btn" style="background-color: var(--bg-input);" onclick="closeModal('editModal')">ยกเลิก</button>
                    <button type="submit" class="btn btn-primary">บันทึกการเปลี่ยนแปลง</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scanner Modal -->
    <div class="modal-overlay" id="scannerModal">
        <div class="modal" style="max-width: 600px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3>สแกนบาร์โค้ด</h3>
                <button onclick="closeScanner()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">&times;</button>
            </div>
            <div id="reader" style="width: 100%; min-height: 300px;"></div>
            <p class="text-center text-muted" style="margin-top: 1rem; font-size: 0.875rem;">นำกล้องส่องไปที่บาร์โค้ดสินค้าเพื่อค้นหาหรือเพิ่มใหม่</p>
        </div>
    </div>
`,
extraJs: `
    const productsData = ` + JSON.stringify(products) + `;

    function openAddModal(prefillCode = '') {
        document.getElementById('addModal').classList.add('modal-active');
        if (prefillCode) {
            document.querySelector('#addModal input[name="code"]').value = prefillCode;
            setTimeout(() => document.querySelector('#addModal input[name="name"]').focus(), 100);
        }
    }

    function openEditModal(productId) {
        const product = productsData.find(p => p._id === productId);
        if (!product) return;

        document.getElementById('editForm').action = '/products/update/' + productId;
        document.getElementById('editCode').value = product.code;
        document.getElementById('editName').value = product.name;
        document.getElementById('editCategory').value = product.category;
        document.getElementById('editPrice').value = product.price;
        document.getElementById('editStock').value = product.stock;
        document.getElementById('editWeight').value = product.weight || 0;
        document.getElementById('editUnit').value = product.unit || 'ชิ้น';
        document.getElementById('editModal').classList.add('modal-active');
    }

    function closeModal(id) {
        document.getElementById(id).classList.remove('modal-active');
    }

    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        const addBarcode = params.get('addBarcode');
        if (addBarcode) openAddModal(addBarcode);
    });

    let html5QrcodeScanner = null;
    function openScanner() {
        document.getElementById('scannerModal').classList.add('modal-active');
        if (!html5QrcodeScanner) {
            html5QrcodeScanner = new Html5QrcodeScanner(
                "reader",
                { fps: 10, qrbox: {width: 250, height: 150} },
                false
            );
            html5QrcodeScanner.render(onScanSuccess, onScanFailure);
        }
    }

    function closeScanner() {
        document.getElementById('scannerModal').classList.remove('modal-active');
        if (html5QrcodeScanner) {
            html5QrcodeScanner.clear().then(() => { html5QrcodeScanner = null; });
        }
    }

    async function onScanSuccess(decodedText) {
        closeScanner();
        Swal.fire({ title: 'กำลังค้นหา...', text: 'รหัส: ' + decodedText, allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

        try {
            const response = await fetch('/api/products/' + decodedText);
            const data = await response.json();
            Swal.close();
            
            if (data.success && data.product) {
                openEditModal(data.product._id);
            } else {
                openAddModal(decodedText);
                Swal.fire({ title: 'ไม่พบสินค้า', text: 'กรุณาเพิ่มสินค้าใหม่เข้าระบบ', icon: 'info', timer: 2000, showConfirmButton: false });
            }
        } catch (err) {
            Swal.fire('ข้อผิดพลาด', 'ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้', 'error');
        }
    }

    function onScanFailure(error) {}

    setTimeout(() => {
        document.querySelectorAll('.alert').forEach(el => el.style.display = 'none');
    }, 4000);
`
}) %>