<%- include('layout', { title: title, user: user, extraCss: `
    .summary-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
        padding: 1rem;
    }
    .summary-card {
        width: 100%;
        max-width: 500px;
        background: var(--bg-card);
        border-radius: var(--radius-lg);
        padding: 2.5rem;
        box-shadow: var(--shadow-lg);
        text-align: center;
        border: 1px solid var(--border);
    }
    .stat-box {
        margin-top: 2rem;
        padding: 1.5rem;
        background: var(--bg-app);
        border-radius: var(--radius-md);
        border-left: 5px solid var(--primary);
    }
    .stat-label {
        font-size: 0.875rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.5rem;
    }
    .stat-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--secondary);
    }
    .stat-sub-value {
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--text-main);
    }
`, body: `
<div class="summary-container">
    <div class="summary-card">
        <div style="margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem;">📊</div>
            <h2 style="color: var(--primary); margin-bottom: 0.25rem;">สรุปยอดขายประจำวัน</h2>
            <p class="text-muted">${today}</p>
        </div>

        <div class="stat-box">
            <div class="stat-label">ยอดขายรวมทั้งหมด</div>
            <div class="stat-value">฿${totalAmount.toLocaleString('th-TH')}</div>
        </div>

        <div class="stat-box" style="border-left-color: var(--secondary);">
            <div class="stat-label">จำนวนรายการขาย (บิล)</div>
            <div class="stat-sub-value">${totalBills} บิล</div>
        </div>

        <div style="margin-top: 2.5rem; display: flex; flex-direction: column; gap: 1rem;">
            <a href="/dashboard" class="btn btn-primary" style="padding: 1rem;">ดูรายละเอียดใน Dashboard</a>
            <a href="/pos" class="btn" style="background: var(--bg-input); color: var(--text-main); padding: 1rem;">ไปหน้าการขาย (POS)</a>
        </div>
    </div>
</div>
`, extraJs: `` }) %>
