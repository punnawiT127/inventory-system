<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ใบเสร็จรับเงิน (Receipt) - <%= sale._id.toString().slice(-6) %></title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Sarabun', sans-serif;
            background-color: #f3f4f6;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            color: #111827;
        }
        .receipt-container {
            background-color: #ffffff;
            width: 100%;
            max-width: 300px; /* Suitable for 80mm thermal printers; 58mm would be ~220px but standard 80mm is safer for modern generic thermal */
            padding: 20px 15px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            border-radius: 4px;
        }
        .header {
            text-align: center;
            margin-bottom: 15px;
            border-bottom: 1px dashed #9ca3af;
            padding-bottom: 15px;
        }
        .header h1 {
            margin: 0 0 5px 0;
            font-size: 1.5rem;
            font-weight: 700;
        }
        .header p {
            margin: 0;
            font-size: 0.875rem;
            color: #4b5563;
            line-height: 1.4;
        }
        .info {
            font-size: 0.875rem;
            margin-bottom: 15px;
            color: #4b5563;
        }
        .info .row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 3px;
        }
        .items-table {
            width: 100%;
            font-size: 0.875rem;
            border-collapse: collapse;
            margin-bottom: 15px;
        }
        .items-table th, .items-table td {
            padding: 4px 0;
            text-align: left;
        }
        .items-table th:last-child, .items-table td:last-child {
            text-align: right;
        }
        .items-table th.center, .items-table td.center {
            text-align: center;
        }
        .items-table tbody tr {
            border-bottom: 1px dotted #e5e7eb;
        }
        .items-table tbody tr:last-child {
            border-bottom: none;
        }
        .totals {
            border-top: 1px dashed #9ca3af;
            border-bottom: 1px dashed #9ca3af;
            padding: 10px 0;
            margin-bottom: 15px;
            font-size: 1rem;
            font-weight: 600;
        }
        .totals .row {
            display: flex;
            justify-content: space-between;
        }
        .totals .total-amount {
            font-size: 1.25rem;
            font-weight: 700;
        }
        .footer {
            text-align: center;
            font-size: 0.875rem;
            color: #4b5563;
        }
        .footer p {
            margin: 5px 0;
        }
        .print-btn {
            display: block;
            width: 100%;
            background-color: #4F46E5;
            color: white;
            border: none;
            padding: 12px;
            border-radius: 6px;
            font-family: inherit;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            transition: background-color 0.2s;
        }
        .print-btn:hover {
            background-color: #4338ca;
        }
        
        /* Print Styles */
        @media print {
            body {
                background-color: transparent;
                padding: 0;
                align-items: flex-start;
            }
            .receipt-container {
                box-shadow: none;
                margin: 0;
                padding: 10px; /* Slight padding for print margins */
                width: 72mm; /* Exact fit for 80mm paper taking margins into account */
                max-width: 100%;
            }
            .print-btn {
                display: none; /* Hide button when printing */
            }
            /* Hide URL and Date headers/footers in most browsers during print */
            @page {
                margin: 0;
            }
        }
    </style>
</head>
<body>
    <div class="receipt-container">
        <div class="header">
            <h1>MND Store</h1>
            <p>ใบเสร็จรับเงินอย่างย่อ</p>
            <p>Receipt</p>
        </div>

        <div class="info">
            <div class="row">
                <span>เลขที่บิล:</span>
                <span><%= sale._id.toString().slice(-8).toUpperCase() %></span>
            </div>
            <div class="row">
                <span>วันที่:</span>
                <span><%= new Date(sale.date).toLocaleString('th-TH', { dateStyle: 'short', timeStyle: 'short' }) %></span>
            </div>
            <div class="row">
                <span>ผู้รับเงิน:</span>
                <span><%= sale.soldBy ? sale.soldBy.username : 'พนักงาน' %></span>
            </div>
        </div>

        <table class="items-table">
            <thead>
                <tr style="border-bottom: 1px solid #111827;">
                    <th>รายการ</th>
                    <th class="center">จำนวน</th>
                    <th>ยอดรวม</th>
                </tr>
            </thead>
            <tbody>
                <% sale.items.forEach(item => { %>
                <tr>
                    <td>
                        <div style="font-weight: 500;"><%= item.product ? item.product.name : 'สินค้ายกเลิก/ลบแล้ว' %></div>
                        <div style="font-size: 0.75rem; color: #6b7280;">@<%= item.priceAtSale.toLocaleString('th-TH') %></div>
                    </td>
                    <td class="center" style="vertical-align: middle;"><%= item.quantity %></td>
                    <td style="vertical-align: middle;">฿<%= (item.priceAtSale * item.quantity).toLocaleString('th-TH') %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>

        <div class="totals">
            <div class="row" style="margin-bottom: 5px;">
                <span>รวมทั้งหมด (<%= sale.items.reduce((acc, item) => acc + item.quantity, 0) %> ชิ้น)</span>
                <span class="total-amount">฿<%= sale.totalAmount.toLocaleString('th-TH') %></span>
            </div>
        </div>

        <div class="footer">
            <p><strong>ขอบคุณที่ใช้บริการ</strong></p>
            <p style="font-size: 0.75rem;">MND Store System</p>
        </div>

        <button class="print-btn" onclick="window.print()">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: text-bottom; margin-right: 5px;">
                <polyline points="6 9 6 2 18 2 18 9"></polyline>
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"></path>
                <rect x="6" y="14" width="12" height="8"></rect>
            </svg>
            พิมพ์ใบเสร็จ
        </button>
    </div>

    <script>
        // Auto-print popup on load for better user experience
        window.addEventListener('load', () => {
            // Optional: Uncomment to automatically trigger print dialog when page loads
            // window.print();
        });
    </script>
</body>
</html>
